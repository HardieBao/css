{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "CodexWidget",
  "mainBinaryName": "CodexWidget",
  "version": "../package.json",
  "identifier": "cn.fengshi.codex-quota-widget",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build:frontend",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Codex CLI 额度小组件",
        "width": 390,
        "height": 236,
        "minWidth": 88,
        "minHeight": 88,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "publisher": "fengshi",
    "copyright": "Copyright (c) 2026 fengshi",
    "category": "Utility",
    "shortDescription": "通过 Codex CLI 读取 Codex 额度的悬浮小组件。",
    "longDescription": "通过本机 Codex CLI 读取 Codex 额度状态的桌面悬浮小组件。",
    "icon": [
      "icons/icon.ico",
      "icons/icon.png",
      "icons/icon.icns"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "languages": [
          "SimpChinese",
          "English"
        ],
        "displayLanguageSelector": false,
        "compression": "lzma"
      }
    },
    "macOS": {
      "signingIdentity": "-"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJFMDk5ODQxMjEwMDY4QTgKUldTb2FBQWhRWmdKTHBPam9MQWZWRk8ybU55TElianVmY2RhM2ZtRGJhV0xQVE55cC9jWkdRdncK",
      "endpoints": [
        "https://github.com/359956085/codex-widget/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
